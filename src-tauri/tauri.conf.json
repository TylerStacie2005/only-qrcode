{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Only QR Code",
  "version": "1.0.1",
  "identifier": "com.tylermecham.onlyqrcode",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Only QR Code",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: data: blob:",
      "dangerousDisableAssetCspModification": ["style-src"]
    }
  },
  "bundle": {
    "iOS": {
      "developmentTeam": "AU75Q8PSKE"
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
