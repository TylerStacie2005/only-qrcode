default_platform(:ios)

platform :ios do
  desc "Upload screenshots and metadata to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: "33VP2RG924",
      issuer_id: "69a6de7b-a8ae-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_33VP2RG924.p8"),
    )

    deliver(
      api_key: api_key,
      app_icon_path: "./fastlane/metadata/app_icon.png",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
      },
      app_review_information: {
        notes: "No demo account needed. Type any text to create a QR code with optional frames and center icons. Switch to Read mode to decode QR codes from images.",
      },
    )
  end

  desc "Submit build to TestFlight"
  lane :testflight_submit do
    api_key = app_store_connect_api_key(
      key_id: "33VP2RG924",
      issuer_id: "69a6de7b-a8ae-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_33VP2RG924.p8"),
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./src-tauri/gen/apple/build/arm64/Only QR Code.ipa",
      skip_submission: false,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      changelog: "New: QR code reader, 14 frame styles, center icon picker, title text, native Save to Photos, Share, responsive sizing.",
    )
  end

  desc "Submit for App Store review"
  lane :submit_for_review do
    api_key = app_store_connect_api_key(
      key_id: "33VP2RG924",
      issuer_id: "69a6de7b-a8ae-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_33VP2RG924.p8"),
    )

    deliver(
      api_key: api_key,
      app_icon_path: "./fastlane/metadata/app_icon.png",
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
      app_rating_config_path: "./fastlane/metadata/age_rating_config.json",
      submission_information: {
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: false,
      },
      app_review_information: {
        first_name: "Tyler",
        last_name: "Mecham",
        phone_number: "+18015555555",
        email_address: "tyler@simplechoicesapp.com",
        notes: "No demo account needed. Type any text to create a QR code with optional frames and center icons. Switch to Read mode to decode QR codes from images.",
      },
    )
  end
end

platform :android do
  desc "Upload AAB to Google Play internal testing track"
  lane :deploy do
    upload_to_play_store(
      json_key: File.expand_path("~/.google/play-service-account.json"),
      package_name: "com.tylermecham.onlyqrcode",
      aab: "./src-tauri/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab",
      track: "internal",
      release_status: "draft",
    )
  end
end
