default_platform(:ios)

platform :ios do
  desc "Upload screenshots and metadata to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: "33VP2RG924",
      issuer_id: "69a6de7b-a8ae-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_33VP2RG924.p8"),
    )

    deliver(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        add_id_info_uses_idfa: false,
      },
      app_review_information: {
        notes: "No demo account needed. Simply type any text and tap Save QR Code to generate a QR code.",
      },
    )
  end

  desc "Submit build to TestFlight"
  lane :testflight_submit do
    api_key = app_store_connect_api_key(
      key_id: "33VP2RG924",
      issuer_id: "69a6de7b-a8ae-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_33VP2RG924.p8"),
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "./src-tauri/gen/apple/build/arm64/Only QR Code.ipa",
      skip_submission: false,
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      changelog: "Added Fastlane automation for store deployments. Fixed export compliance flag.",
    )
  end
end

platform :android do
  desc "Upload AAB to Google Play internal testing track"
  lane :deploy do
    upload_to_play_store(
      json_key: File.expand_path("~/.google/play-service-account.json"),
      package_name: "com.tylermecham.onlyqrcode",
      aab: "./src-tauri/gen/android/app/build/outputs/bundle/universalRelease/app-universal-release.aab",
      track: "internal",
      release_status: "draft",
    )
  end
end
